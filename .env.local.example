# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: Supabase service role key (server-side only, NEVER expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Claude API (for AI insights, optional)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Email via Resend (optional — queued if not set)
# RESEND_API_KEY=re_your-resend-api-key

# SMS via Africa's Talking (optional — queued if not set)
# AT_API_KEY=your-africastalking-api-key
# AT_USERNAME=your-africastalking-username

# WhatsApp Business API — Meta Cloud API (optional — silently skipped if not set)
# Get these from Meta Business Manager → WhatsApp → API Setup
# WHATSAPP_API_TOKEN=your-permanent-system-user-token
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id
# WHATSAPP_API_VERSION=v21.0

# Web Push VAPID keys (optional — queued if not set)
# Generate with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key
